APP_NAME="Türkmen Sözlük"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=tk
APP_FALLBACK_LOCALE=tk
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=turkmen_dictionary
DB_USERNAME=turkmen
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

DICTIONARY_SQLITE_PATH=storage/app/turkmen.sqlite
DICTIONARY_SQLITE_TABLE=words
DICTIONARY_SQLITE_WORD_COLUMN=word
DICTIONARY_SQLITE_MEANING_COLUMN=definitions

MAIL_MAILER=log

MODERATION_REPORT_THRESHOLD=5
MODERATION_APPEAL_RESTORE_THRESHOLD=3
MODERATION_ACTIVE_ACCOUNT_DAYS=7
MODERATION_ACTIVE_VOTE_COUNT=3
